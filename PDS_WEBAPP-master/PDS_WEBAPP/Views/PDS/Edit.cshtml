@model PDS_WebApp.Models.PersonalDataSheet

@{
    ViewData["Title"] = "Edit Personal Data Sheet";
}

<h2>Edit Personal Data Sheet</h2>
<hr />

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />

    <!-- PERSONAL INFORMATION -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white fw-bold">I. Personal Information</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="LastName" class="form-label fw-semibold"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="FirstName" class="form-label fw-semibold"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="MiddleName" class="form-label fw-semibold"></label>
                    <input asp-for="MiddleName" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="NameExtension" class="form-label fw-semibold"></label>
                    <input asp-for="NameExtension" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="PlaceOfBirth" class="form-label fw-semibold"></label>
                    <input asp-for="PlaceOfBirth" class="form-control" />
                    <span asp-validation-for="PlaceOfBirth" class="text-danger"></span>
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="Sex" class="form-label fw-semibold"></label>
                    <select asp-for="Sex" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Sex" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="CivilStatus" class="form-label fw-semibold"></label>
                    <select asp-for="CivilStatus" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="Single">Single</option>
                        <option value="Married">Married</option>
                        <option value="Widowed">Widowed</option>
                        <option value="Separated">Separated</option>
                        <option value="Others">Others</option>
                    </select>
                    <span asp-validation-for="CivilStatus" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-2 mb-3">
                    <label asp-for="Height" class="form-label fw-semibold"></label>
                    <input asp-for="Height" class="form-control" />
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="Weight" class="form-label fw-semibold"></label>
                    <input asp-for="Weight" class="form-control" />
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="BloodType" class="form-label fw-semibold"></label>
                    <select asp-for="BloodType" class="form-select">
                        <option value="">-- Select --</option>
                        <option>A+</option><option>A-</option>
                        <option>B+</option><option>B-</option>
                        <option>AB+</option><option>AB-</option>
                        <option>O+</option><option>O-</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Citizenship" class="form-label fw-semibold"></label>
                    <input asp-for="Citizenship" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="GSISIdNo" class="form-label fw-semibold"></label>
                    <input asp-for="GSISIdNo" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="PagIbigIdNo" class="form-label fw-semibold"></label>
                    <input asp-for="PagIbigIdNo" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="PhilHealthNo" class="form-label fw-semibold"></label>
                    <input asp-for="PhilHealthNo" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="SSSNo" class="form-label fw-semibold"></label>
                    <input asp-for="SSSNo" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="TINNo" class="form-label fw-semibold"></label>
                    <input asp-for="TINNo" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="AgencyEmployeeNo" class="form-label fw-semibold"></label>
                    <input asp-for="AgencyEmployeeNo" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- CONTACT INFORMATION -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white fw-bold">II. Contact Information</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-9 mb-3">
                    <label asp-for="ResidentialAddress" class="form-label fw-semibold"></label>
                    <input asp-for="ResidentialAddress" class="form-control" />
                    <span asp-validation-for="ResidentialAddress" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="ResidentialZipCode" class="form-label fw-semibold"></label>
                    <input asp-for="ResidentialZipCode" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-9 mb-3">
                    <label asp-for="PermanentAddress" class="form-label fw-semibold"></label>
                    <input asp-for="PermanentAddress" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="PermanentZipCode" class="form-label fw-semibold"></label>
                    <input asp-for="PermanentZipCode" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="MobileNumber" class="form-label fw-semibold"></label>
                    <input asp-for="MobileNumber" class="form-control" />
                    <span asp-validation-for="MobileNumber" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="TelephoneNo" class="form-label fw-semibold"></label>
                    <input asp-for="TelephoneNo" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="EmailAddress" class="form-label fw-semibold"></label>
                    <input asp-for="EmailAddress" class="form-control" />
                    <span asp-validation-for="EmailAddress" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
